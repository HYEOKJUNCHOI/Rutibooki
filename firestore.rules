rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 본인 데이터만 접근. 하위 컬렉션(books/reading/logs/quotes)까지 재귀 허용.
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
      match /{subcollection=**} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
    }

    // 표지 캐시 — 전체 유저 공유 읽기, 로그인 유저만 쓰기.
    match /coverCache/{key} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
